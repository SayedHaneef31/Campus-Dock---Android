<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Top Bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="8dp">

            <ImageView
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:id="@+id/backButton"
                android:src="@drawable/ic_back"
                android:contentDescription="Back"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="Profile"
                android:textSize="20sp"
                android:textStyle="bold"/>

            <ImageView
                android:id="@+id/btnSettings"
                android:layout_width="25dp"
                android:layout_height="25dp"
                android:src="@drawable/setting"
                android:contentDescription="Settings"/>
        </LinearLayout>

        <!-- Profile Header with Floating Edit Button -->
        <FrameLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="8dp">

            <ImageView
                android:id="@+id/profileImage"
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:src="@drawable/profile_pic"
                android:scaleType="centerCrop"
                android:clipToOutline="true"
                android:background="@drawable/circle_background"
                android:contentDescription="Profile Picture"/>

            <!-- Loading ProgressBar -->
            <ProgressBar
                android:id="@+id/profileUploadProgress"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="center"
                android:visibility="gone"
                android:indeterminateTint="#4A90E2" />

            <!-- Small Edit Button at bottom-right -->
            <FrameLayout
                android:id="@+id/profileImageOverlay"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_gravity="bottom|end"
                android:layout_marginEnd="4dp"
                android:layout_marginBottom="4dp"
                android:background="@drawable/circle_background"
                android:backgroundTint="#4A90E2">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_camera"
                    android:contentDescription="Change Photo"
                    app:tint="@android:color/white" />
            </FrameLayout>
        </FrameLayout>

        <TextView
            android:id="@+id/profileName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Sayed Haneef"
            android:textSize="28sp"
            android:textStyle="bold"
            android:gravity="center"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/profileEmail"
            android:text="sayed.22b0121094@abes.ac.in"
            android:textSize="14sp"
            android:textColor="@color/gray"
            android:gravity="center"
            android:layout_marginBottom="16dp"/>

        <!-- Example: Campus Highlight card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:backgroundTint="#6CA6BA"
            app:cardCornerRadius="20dp"
            app:cardElevation="8dp">

            <TextView
                android:id="@+id/profileHighlightTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:padding="24dp"
                android:text="🌟 Sayed's Highlight 🌟"
                android:textColor="@android:color/white"
                android:textSize="18sp"
                android:textStyle="bold"/>
        </com.google.android.material.card.MaterialCardView>



        <!-- 🔽 Expandable Section 1: Order History -->
        <include layout="@layout/profile_item_expandable_section"
            android:id="@+id/section_order_history"/>

        <!-- 🔽 Expandable Section 2: Marketplace Listings -->
        <include layout="@layout/profile_item_expandable_section"
            android:id="@+id/section_marketplace"/>

        <!-- 🔽 Expandable Section 3: Social Posts -->
        <include layout="@layout/profile_item_expandable_section"
            android:id="@+id/section_social_posts"/>

    </LinearLayout>
</ScrollView>
